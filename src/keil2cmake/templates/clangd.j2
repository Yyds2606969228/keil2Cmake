# clangd config generated by Keil2Cmake
# ARM-GCC only

CompileFlags:
  Remove: [
    -mcpu=*,
    -mthumb*,
    -mfloat-abi=*,
    -mfpu=*,
    -ffunction-sections,
    -fdata-sections,
    -g,
    -O*,
    -std=*,
    -W*,
    --cpu=*,
    --apcs=*,
    --split_sections,
    --debug,
    --cpp,
    --strict,
    -D__CC_ARM
  ]

  Add:
{% for flag in add_flags %}    - '{{ flag }}'
{% endfor %}

Diagnostics:
  Suppress: [
    unknown-warning-option,
    invalid_token_after_toplevel_declarator,
    option_ignored,
    unused-command-line-argument,
    pp_file_not_found
  ]

Index:
  Background: Build
  StandardLibrary: false
