ENTRY(Reset_Handler)

MEMORY
{
    FLASH (rx)  : ORIGIN = {{ rom_base }}, LENGTH = {{ rom_size }}
    RAM   (rwx) : ORIGIN = {{ ram_base }}, LENGTH = {{ ram_size }}
}

SECTIONS
{
    .isr_vector :
    {
        KEEP(*(.isr_vector))
    } > FLASH

    .text :
    {
        *(.text*)
        *(.rodata*)
        KEEP(*(.init))
        KEEP(*(.fini))
    } > FLASH

    .ARM.extab : { *(.ARM.extab* .gnu.linkonce.armextab.*) } > FLASH
    .ARM.exidx :
    {
        __exidx_start = .;
        *(.ARM.exidx* .gnu.linkonce.armexidx.*)
        __exidx_end = .;
    } > FLASH

    .data : AT (ADDR(.text) + SIZEOF(.text))
    {
        __data_start__ = .;
        *(.data*)
        __data_end__ = .;
    } > RAM

    .bss :
    {
        __bss_start__ = .;
        *(.bss*)
        *(COMMON)
        __bss_end__ = .;
    } > RAM

{% if stack_size or heap_size %}
    ._user_heap_stack :
    {
        . = ALIGN(8);
        PROVIDE(end = .);
        PROVIDE(_end = .);
{% if heap_size %}
        . = . + {{ heap_size }};
{% else %}
        . = . + 0;
{% endif %}
{% if stack_size %}
        . = . + {{ stack_size }};
{% else %}
        . = . + 0;
{% endif %}
        . = ALIGN(8);
    } > RAM
{% endif %}
}
