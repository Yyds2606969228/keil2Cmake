    COMMAND ${CMAKE_COMMAND} -E echo ""
    COMMAND ${CMAKE_COMMAND} -E echo "Build Commands:"
    COMMAND ${CMAKE_COMMAND} -E echo "  cmake --build --preset keil2cmake"
    COMMAND ${CMAKE_COMMAND} -E echo "  cmake --build --preset build"
    COMMAND ${CMAKE_COMMAND} -E echo "  cmake --build --preset check"
