    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_ENABLE_STYLE=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_ENABLE_PERFORMANCE=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_ENABLE_PORTABILITY=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_ENABLE_INFORMATION=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_ENABLE_UNUSED_FUNCTION=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_ENABLE_MISSING_INCLUDE=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_CHECKCPP_INCONCLUSIVE=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo ""
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_USE_NEWLIB_NANO=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "    Enable newlib-nano (ARM-GCC)"
    COMMAND ${CMAKE_COMMAND} -E echo ""
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_NEWLIB_NANO_PRINTF_FLOAT=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "    Enable printf float when using newlib-nano"
    COMMAND ${CMAKE_COMMAND} -E echo ""
    COMMAND ${CMAKE_COMMAND} -E echo "  K2C_NEWLIB_NANO_SCANF_FLOAT=<ON|OFF>"
    COMMAND ${CMAKE_COMMAND} -E echo "    Enable scanf float when using newlib-nano"
    COMMAND ${CMAKE_COMMAND} -E echo ""
    COMMAND ${CMAKE_COMMAND} -E echo "Examples:"
    COMMAND ${CMAKE_COMMAND} -E echo "  cmake -B build -DK2C_OPTIMIZE_LEVEL=3"
    COMMAND ${CMAKE_COMMAND} -E echo "  cmake --build --preset check"
    COMMAND ${CMAKE_COMMAND} -E echo "  cmake --build build --target show-options"
